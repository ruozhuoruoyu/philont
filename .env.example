# Philont example environment — copy to `.env` and fill in.
# Only ANTHROPIC_API_KEY is strictly required; everything else has sane defaults.

# ── Main model (Anthropic-compatible) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Custom / proxy endpoint (defaults to https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Model id (defaults to a current Claude model)
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# Provider switch. Default 'anthropic' uses the ANTHROPIC_* config above
# (Anthropic Messages protocol — Claude, or DeepSeek's /anthropic endpoint).
# Set to an OpenAI-compatible provider to use those instead:
#   LLM_PROVIDER=openai     # generic; OPENAI_BASE_URL reaches ANY compatible endpoint
#     OPENAI_API_KEY=...  OPENAI_MODEL=...  OPENAI_BASE_URL=https://api.deepseek.com
#   LLM_PROVIDER=glm        # 智谱; GLM_API_KEY / GLM_MODEL (base url built in)
#   LLM_PROVIDER=kimi       # Moonshot; KIMI_API_KEY / KIMI_MODEL
#   LLM_PROVIDER=minimax    # MINIMAX_API_KEY / MINIMAX_MODEL
#   LLM_PROVIDER=gemini     # GEMINI_API_KEY / GEMINI_MODEL (Google OpenAI-compat)
# Internally philont always uses Anthropic message structure; OpenAI-compatible
# providers are translated both ways automatically.
# LLM_PROVIDER=anthropic

# ── Auxiliary small model (optional) ────────────────────────────────────────
# Used for cheap distillation (web-fetch summarization, reflection, etc.).
# Falls back to the main model when unset. Protocol: openai | anthropic.
# AUX_LLM_BASE_URL=
# AUX_LLM_API_KEY=
# AUX_LLM_MODEL=
# AUX_LLM_PROTOCOL=openai

# ── Vision (optional) ───────────────────────────────────────────────────────
# The `vision` tool needs a MULTIMODAL model. If your main model isn't multimodal
# (e.g. DeepSeek), point vision at a dedicated multimodal model here — independent
# of the main model. Supports both OpenAI-compatible and Anthropic protocols.
# VISION_LLM_BASE_URL=
# VISION_LLM_API_KEY=
# VISION_LLM_MODEL=
# Protocol: openai (default) | anthropic. Auto-detected from the base URL if unset
# (URLs containing "anthropic" -> anthropic). Most domestic multimodal models
# (Qwen-VL, GLM-4V, Step, MiniMax) are OpenAI-compatible -> leave as openai.
# VISION_LLM_PROTOCOL=openai
#
# Examples:
#   Qwen-VL (DashScope, OpenAI-compatible):
#     VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#     VISION_LLM_MODEL=qwen-vl-max
#   GLM-4V (Zhipu, OpenAI-compatible):
#     VISION_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#     VISION_LLM_MODEL=glm-4v
#   Claude (Anthropic protocol):
#     VISION_LLM_BASE_URL=https://api.anthropic.com
#     VISION_LLM_PROTOCOL=anthropic
#     VISION_LLM_MODEL=claude-sonnet-4-6

# ── Tools / capabilities (optional) ─────────────────────────────────────────
# Enable browser automation via Playwright MCP (local stdio, no extra account).
# PHILONT_MCP_BROWSER=1
# Path to an MCP server config file (default: ~/.philont/mcp.json)
# PHILONT_MCP_CONFIG=
# Web search backend key (if your webSearch tool uses Brave).
# BRAVE_SEARCH_API_KEY=

# ── Deep reasoning (optional) ───────────────────────────────────────────────
# The deep_explore tool (multi-step conjecture attack via an internal mini-loop
# with reason_decompose/reason_record + local retrieval) is ON by default.
# Set to 0 to disable it.
# PHILONT_DEEP_EXPLORE=0
# Per-round LLM<->tool turn cap inside one deep_explore round (default 40, 5-100).
# Raise it when hard problems get cut off before they unfold.
# PHILONT_DEEP_EXPLORE_MAX_ITERS=40
# Cross-turn token budget for one reasoning session (default 300000, min 50000).
# PHILONT_DEEP_EXPLORE_TOKEN_BUDGET=300000
# Wall-clock budget per reasoning round (default 720000 = 12min, min 30000). Kept
# safely under the 20min turn hard deadline so a long round stops gracefully (tree
# saved, resumable via "continue") instead of hitting TurnDeadlineError.
# PHILONT_DEEP_EXPLORE_ROUND_DEADLINE_MS=720000

# ── Channels (optional) ─────────────────────────────────────────────────────
# Telegram bot channel. Create a bot with @BotFather to get the token.
# TELEGRAM_ENABLED=1
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# DM access: open (default) | allowlist | disabled. With allowlist, set the
# numeric Telegram user id(s) allowed to talk to the bot.
# TELEGRAM_DM_POLICY=open
# TELEGRAM_ALLOWED_USERS=11111111,22222222
# Group access: open (default) | allowlist | disabled.
# TELEGRAM_GROUP_POLICY=open
# TELEGRAM_ALLOWED_GROUPS=-1001234567890
# Proxy for api.telegram.org (Telegram is blocked in some regions). Applies ONLY
# to the Telegram channel — domestic services keep direct connections. Falls back
# to HTTPS_PROXY / ALL_PROXY if unset. e.g. a local Clash HTTP proxy:
# TELEGRAM_PROXY=http://127.0.0.1:7890
#
# WeChat channel. First scan-login via `npm run wechat:login`.
# WECHAT_ENABLED=1
# DM access: allowlist (default, safe) | open | disabled. NOTE: with allowlist and
# WECHAT_DM_POLICY=open
# WECHAT_ALLOWED_USERS=o9cq8xxxxxxxxxxxxxxxxxxxxx@im.wechat
# Group access: open (default) | allowlist | disabled.
# WECHAT_GROUP_POLICY=open
# WECHAT_ALLOWED_GROUPS=

# ── Memory / runtime (optional) ─────────────────────────────────────────────
# SQLite memory database path (default: ~/.philont/memory/memory.sqlite)
# MEMORY_DB_PATH=
# Kill switch for the idle-time autonomous loop (1 = on, 0 = off; default on).
# PHILONT_AUTONOMOUS=1
# Per-day LLM token ceiling for the autonomous loop; once hit it skips the rest of
# the day's ticks ("daily token cap reached" in the logs). Raise it to let the loop
# do more idle work; 0 = unlimited. Default 20000.
# PHILONT_AUTONOMOUS_DAILY_TOKENS=20000
# Conscience gate (off by default): when on, every outbound message to a human (WeChat/Telegram)
# is first judged by one LLM call against a short safety constitution (no harm to people:
# defamation/doxxing/disinformation/harm-enabling instructions). Fail-open — if the judge errors
# or times out, the message is sent. Adds one LLM call of latency/cost per reply when enabled.
# PHILONT_CONSCIENCE_GATE=off
# Background auto-advance for deep_explore (off by default). When on, a reasoning session the agent
# has opted in (deep_explore auto_on) is advanced round-by-round in the background — no need to keep
# typing "continue" — and progress is pushed proactively; it stops on solved or after a few stuck rounds.
# PHILONT_DEEP_EXPLORE_AUTO_ADVANCE=off
# IANA timezone for scheduling / time display (default: system).
# AGENT_TIMEZONE=Asia/Singapore
# Agent server HTTP + WebSocket port (default: 20266). The launcher injects this.
# PHILONT_PORT=20266

# ── Network proxy (optional) ────────────────────────────────────────────────
# Global outbound proxy. When set, ALL fetch-based traffic (Claude API, aux model,
# webFetch/webSearch/downloadFile, WeChat, Telegram) is routed through it via
# undici's global dispatcher. Telegram can still override with TELEGRAM_PROXY.
# Standard HTTPS_PROXY / ALL_PROXY are also honored. Note: no NO_PROXY allowlist
# yet — a global proxy also routes domestic LLM gateways through it.
# PHILONT_PROXY=http://127.0.0.1:7890
