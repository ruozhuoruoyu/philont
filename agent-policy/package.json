{
  "name": "@agent/policy",
  "version": "0.1.0",
  "description": "Policy layer for philont: PermissionMatrix + AuditLog + PolicyDelegate",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
