# philont server 启动环境变量(dotenv 自动 load /server/.env)
#
# 用法:
#   1. cp .env.example .env
#   2. 按需改下面的值
#   3. npm run dev   ← 不再需要在命令行前设变量
#
# .env 已被 .gitignore 忽略,放心写真实凭证 / token

# ── LLM ────────────────────────────────────────────────────────
# Anthropic API key(必填,philont 默认走 Claude)
ANTHROPIC_API_KEY=

# ── 辅助小模型(可选)─────────────────────────────────────────
# webFetch 蒸馏 / 后续 commit-msg 生成 / 网页分类等"非主推理"任务,
# 配上便宜的小模型可以省 Claude 配额。OpenAI Chat Completions 兼容
# 端点都可以(DeepSeek / Qwen / GLM / Moonshot / Groq…)。
#
# 三项必须同时配齐才生效;任一缺失 → 透明回退到上面的主模型(Claude)。
# 完全不配 → 也不报错,只是 webFetch 带 prompt 蒸馏的能力降级到截断。
# AUX_LLM_BASE_URL=https://api.deepseek.com/v1
# AUX_LLM_API_KEY=
# AUX_LLM_MODEL=deepseek-chat
#
# 协议选择(2026-05-14):
#   AUX_LLM_PROTOCOL=openai     # 默认,走 POST /chat/completions(DeepSeek/Qwen/...)
#   AUX_LLM_PROTOCOL=anthropic  # 走 POST /v1/messages(Anthropic 官方或网关如
#                                # neolink.vnet.com / anthropic-shim)
# 不显式设时按 baseUrl 启发式:含 'anthropic' → anthropic;其它一律 openai。
# AUX_LLM_PROTOCOL=anthropic

# ── 深度探索 deep_explore(可选)──────────────────────────────────
# 开启 deep_explore 工具(内部 mini-loop 多步攻命题:reason_decompose/record + 本地检索)。
# PHILONT_DEEP_EXPLORE=1
# 单轮 mini-loop 的 LLM↔工具来回上限(默认 40,范围 5-100)。硬命题没展开就被截时调高。
# PHILONT_DEEP_EXPLORE_MAX_ITERS=40
# 单个推理会话跨 turn 的 token 总预算(默认 300000,下限 50000)。
# PHILONT_DEEP_EXPLORE_TOKEN_BUDGET=300000
# 单轮墙钟时间上限(默认 720000=12min,下限 30000)。安全低于 20min turn 硬 deadline:
# 单轮跑久了优雅停(树已存,回复"继续"接着推),不再撞 TurnDeadlineError + 留孤儿循环。
# PHILONT_DEEP_EXPLORE_ROUND_DEADLINE_MS=720000

# ── 已抓取资源本地落盘(Phase 10,2026-05-14)────────────────────
# webFetch / readFile 成功结果自动落 ~/.philont/workspace/fetched/<file>。
# aux LLM 调 plan_review/verifyClose 时优先读本地文件(而非看 URL 字符串
# placeholder)→ aux 真能看到 guide.md / SOUL.md 内容判语义层 gap。
#
# PHILONT_FETCHED_ENABLED=0          # 关闭整个 store(回到 Phase 9.2 行为)
# PHILONT_FETCHED_TTL_DAYS=30        # 默认 0 = 永久;> 0 启用 decay
# PHILONT_FETCHED_MAX_TEXT_MB=10     # 单文本文件大小上限(MB)
# PHILONT_FETCHED_MAX_BIN_MB=50      # 单二进制文件大小上限(MB)
# PHILONT_FETCHED_AUX_MAX_CHARS=80000 # aux prompt 内 guide 内容字符上限
# PHILONT_HOME=/path/to/philont       # 改根目录(默认 ~/.philont/)

# ── Tool loop iteration 上限(Phase 10,2026-05-14)────────
# fast / slow 模式分级 cap。slow 任务(复杂、含 guide / plan-aux 反复 revise)
# 默认 cap = fast × 2,因为 plan-aux review-revise 循环就吃 6-10 iter。
#
# PHILONT_TOOL_LOOP_MAX=20           # fast 模式 cap(默认 20,范围 5-100)
# PHILONT_TOOL_LOOP_MAX_SLOW=40      # slow 模式 cap(默认 fast×2 上限 60,范围 10-100)

# ── WeChat(个人微信 / iLink Bot)─────────────────────────────
# 启用 WeChat gateway(须先跑 `npm run wechat:login` 扫码登录)
WECHAT_ENABLED=1

# DM 准入策略:open(任何人都能 DM)/ allowlist(仅下面列表)/ disabled
# 只有自己用就 open 最方便;给别人也用先 allowlist 限定
WECHAT_DM_POLICY=open

# 群消息准入:disabled 默认禁(避免被拉群后机器人被吵醒)
WECHAT_GROUP_POLICY=open

# 多账户场景显式指定,否则用 listAccounts() 唯一账户
# WECHAT_ACCOUNT_ID=o9cq801SI55LNCfpPkrmkUwB0hlU@im.wechat

# 自部署 / 海外接入点覆盖(默认 ilinkai.weixin.qq.com)
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com

# allowlist 模式下放行的 user/group id,逗号分隔
# WECHAT_ALLOWED_USERS=user1@im.wechat,user2@im.wechat
# WECHAT_ALLOWED_GROUPS=group-id-1

# ── 记忆 / Memory ──────────────────────────────────────────────
# 自定义 SQLite 路径(默认 ~/.philont/memory.db)
# MEMORY_DB_PATH=

# Memory backup interval / retain
# MEMORY_BACKUP_INTERVAL_MS=21600000      # 6h
# MEMORY_BACKUP_RETAIN=28                 # 4 周(14d * 2/d)

# ── Timeline / 召回预算 ────────────────────────────────────────
# 每轮上下文召回的 token 预算(K8 调优后默认值)
# TIMELINE_RECENT_BUDGET=8000
# TIMELINE_RECALL_BUDGET=4000

# ── 文件下载 ───────────────────────────────────────────────────
# downloadFile 工具的默认落盘目录。dest 省略时文件落到这里,
# 文件名优先取响应头 Content-Disposition,其次 URL 末段,自动避免覆盖。
# 必须是绝对路径;相对路径被忽略,回退到 ~/.philont/downloads。
# PHILONT_DOWNLOAD_DIR=/path/to/downloads

# ── 时区 ───────────────────────────────────────────────────────
# 给 calendar / schedule 工具用,默认 UTC
# AGENT_TIMEZONE=Asia/Shanghai

# ── 端口 ───────────────────────────────────────────────────────
# agent server 的 HTTP + WebSocket 端口,默认 20266(避开常见的 3000)。launcher 会注入。
# PHILONT_PORT=20266

# ── 全局出网代理 ───────────────────────────────────────────────
# 设了之后,所有走 fetch 的出网(Claude / aux 小模型 / webFetch / webSearch /
# downloadFile / WeChat / Telegram)都经它转发(undici 全局 dispatcher)。
# Telegram 可用 TELEGRAM_PROXY 单独覆盖;HTTPS_PROXY / ALL_PROXY 也认。
# 已知限制:暂不支持 NO_PROXY 白名单,国内直连网关也会走代理。
# PHILONT_PROXY=http://127.0.0.1:7890
