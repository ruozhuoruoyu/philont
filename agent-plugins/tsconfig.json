{
  "compilerOptions": {
    "target":      "ES2022",
    "module":      "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir":      "./dist",
    "rootDir":     "./",
    "strict":      true,
    "declaration": true,
    "sourceMap":   true,
    "lib":         ["ES2022"],
    "types":       ["node"]
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
